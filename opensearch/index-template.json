{
  "index_patterns": ["mail-platform-logs-*"],
  "template": {
    "mappings": {
      "properties": {
        "@timestamp":  { "type": "date" },
        "timestamp":   { "type": "date" },
        "level":       { "type": "keyword" },
        "serviceId":   { "type": "keyword" },
        "serviceName": { "type": "keyword" },
        "logger_name": { "type": "keyword" },
        "thread_name": { "type": "keyword" },
        "message":     { "type": "text" },
        "stackTrace":  { "type": "text" },
        "resolved":    { "type": "boolean" },
        "resolvedAt":  { "type": "keyword" },
        "resolvedBy":  { "type": "keyword" }
      }
    }
  }
}
