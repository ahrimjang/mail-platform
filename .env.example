# 운영 배포용 환경변수 목록 (예시)
#
# 로컬 개발은 이 파일 없이 그대로 동작합니다 — application.yml 의 ${VAR:기본값} 기본값이
# docker compose 의 dev 인프라(localhost)를 가리키기 때문입니다.
# 운영 배포(docker-compose.prod.yml)는 같은 디렉터리의 .env 를 자동으로 읽습니다 —
# 이 파일을 .env 로 복사해 실값을 채우세요.
# ⚠️ 실제 값을 채운 .env 는 절대 커밋하지 마세요 (.gitignore 등록됨).

# ── 상태 저장소 (Postgres) — api / worker / admin 공통 ─────────────
DB_URL=jdbc:postgresql://your-db-host:5432/maildb
DB_USERNAME=maildb
DB_PASSWORD=change-me

# ── 발송 작업큐 (RabbitMQ) — api / worker ──────────────────────────
RABBITMQ_HOST=your-mq-host
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=mail
RABBITMQ_PASSWORD=change-me

# ── 이벤트 스트림 (Kafka) — api / worker ───────────────────────────
KAFKA_BOOTSTRAP_SERVERS=your-kafka-host:9092

# ── 인증/웹훅 (mail-api) ────────────────────────────────────────────
# HS512 서명이라 64바이트 이상의 랜덤 문자열이어야 합니다. 생성 예:
#   openssl rand -base64 64 | tr -d '\n'
APP_JWT_SECRET=
APP_JWT_EXPIRATION_MINUTES=120
# 바운스 웹훅 공유 시크릿 (프로바이더가 X-Webhook-Token 헤더로 echo)
APP_WEBHOOK_SECRET=
# SES(SNS) 웹훅의 아마존 서명검증 — 운영은 반드시 true(기본값). 로컬에서 샘플
# 페이로드를 curl로 흘릴 때만 false로.
APP_WEBHOOK_SNS_VERIFY_SIGNATURE=true

# ── SMTP 발송 (mail-worker) ────────────────────────────────────────
# dev 기본은 MailHog(localhost:1025, 무인증). 운영은 실제 릴레이로.
SMTP_HOST=email-smtp.ap-northeast-2.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true
# smtp | logging (logging 은 발송 없이 로그만)
MAIL_SENDER_TYPE=smtp

# ── 메트릭 (mail-worker) ───────────────────────────────────────────
# 워커의 유일한 HTTP 표면 — Prometheus 가 /actuator/prometheus 를 긁는 포트.
WORKER_METRICS_PORT=8082

# ── 모니터링 (docker-compose.prod.yml) ─────────────────────────────
# 프로드 Grafana 는 익명 접근이 꺼져 있고 admin 계정으로 로그인합니다.
GRAFANA_ADMIN_PASSWORD=change-me

# ── 추적/수신거부 링크의 공개 주소 (mail-worker) ────────────────────
# 수신자 메일 본문에 박히는 URL 이므로 반드시 외부에서 접근 가능한 주소여야 합니다.
APP_BASE_URL=https://mail.example.com
